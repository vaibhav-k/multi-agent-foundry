# ==========================================================
# Application
# ==========================================================

LOG_LEVEL=INFO

# ==========================================================
# Azure AI Foundry Project
# ==========================================================

AZURE_AI_PROJECT_ENDPOINT=https://<resource>.services.ai.azure.com/api/projects/proj-default

# Model deployments (Azure AI Foundry)
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5.4-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# ==========================================================
# Azure AI Inference
# ==========================================================

AZURE_INFERENCE_ENDPOINT=https://<resource>.services.ai.azure.com/models
AZURE_INFERENCE_KEY=...

# ==========================================================
# Azure AI Search
# ==========================================================

AZURE_SEARCH_ENDPOINT=https://<resource>.search.windows.net
AZURE_SEARCH_KEY=...
AZURE_SEARCH_INDEX=enterprise-documents